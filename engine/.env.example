# Copy to `.env` and set secrets. Loaded by Pydantic Settings (`env_file=".env"`) and by
# Docker Compose via `env_file` on the `api` service (see `docker-compose.yml`).

# -----------------------------------------------------------------------------
# API keys — at least one MUST be non-empty (validated in `app.config.Settings`)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# LiteLLM — primary / fallback (see `app.dependencies.get_llm_wrapper`)
# -----------------------------------------------------------------------------
PRIMARY_MODEL=gpt-4o-mini
FALLBACK_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT=30
LLM_RETRIES=2

# -----------------------------------------------------------------------------
# Redis — exact-match cache (`app.dependencies.get_cache`)
# -----------------------------------------------------------------------------
# Same URL the `api` Compose service uses on the default compose network (hostname `redis`,
# port 6379). Compose also sets this under `services.api.environment.REDIS_URL`.
REDIS_URL=redis://redis:6379
CACHE_TTL=86400

# -----------------------------------------------------------------------------
# Jinja prompt pack for synchronous POST /api/v1/estimate (subfolder app/prompts/estimation/<version>/)
# -----------------------------------------------------------------------------
ESTIMATION_PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# Local uvicorn on the host (no Docker)
# -----------------------------------------------------------------------------
# Use a separate `.env` or override: `REDIS_URL=redis://127.0.0.1:6379` when Redis is only
# published on localhost (e.g. `docker compose up redis` and app runs outside Compose).
